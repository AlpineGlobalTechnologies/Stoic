<%= form_with(model: [:admin, author]) do |form| %>
  <% if author.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(author.errors.count, "error") %> prohibited this author from being saved:</h2>

      <ul>
        <% author.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group mb-3">
    <%= form.label :avatar, "Author Avatar" %>
    <%= form.file_field :avatar, class: "form-control" %>
     <% if author.avatar.attached? %>
      <div class="mt-2">
        <%= image_tag author.avatar, class: "img-thumbnail", width: 150, height: 150, style: "object-fit: cover; aspect-ratio: 1/1;" %>
      </div>
    <% end %>
  </div>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :bio, style: "display: block" %>
    <%= form.textarea :bio %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
