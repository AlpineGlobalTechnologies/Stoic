<p style="color: green"><%= notice %></p>

<%= render @author %>

<div>
  <%= link_to "Edit This Author", edit_admin_author_path(@author), class:"cta-button" %>
  <%= link_to "Back to Authors", admin_authors_path, class:"cta-button" %>
  <%= button_to "Destroy This Author", admin_author_path(@author), method: :delete, data: { confirm: "Are you sure?" }, class:"cta-button" %>
</div>
