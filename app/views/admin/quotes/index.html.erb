<!-- app/views/admin/quotes/index.html.erb -->
<h1>Quotes</h1>

<%= link_to "New Quote", new_admin_quote_path, class: "btn btn-success mb-3" %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Image</th>
      <th>Title</th>
      <th>Author</th>
      <th>Date</th>
      <th>Category</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <% @quotes.each do |quote| %>
      <tr>
      <td>
      <% if quote.image.attached? %>
            <%= image_tag quote.image, class: "img-thumbnail", width:50, height:50, style:'object-fit: cover;aspect-ratio: 1/1;' %>
        <% end %>
        </td>
        <td><%= quote.title %></td>
        <td><%= quote.author.presence || "—" %></td>
        <td><%= quote.date&.strftime("%b %d, %Y") || "—" %></td>
        <td><%= quote.category.presence || "—" %></td>
        <td>
          <%= link_to "Show", admin_quote_path(quote), class: "btn btn-sm btn-info" %>
          <%= link_to "Edit", edit_admin_quote_path(quote), class: "btn btn-sm btn-primary" %>
          <%= button_to "Delete", admin_quote_path(quote),
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>