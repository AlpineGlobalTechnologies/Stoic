<div class="quote card mb-3">
  <div class="card-body">
    <blockquote class="blockquote animate-fade-up">

      <p><%= quote.description %></p>

      <footer class="blockquote-footer animate-fade-in">
        <%= quote.title %> —

        <cite title="Author" class="animate-fade-in">
          <%= quote.author&.name || "Anonymous" %>

          <% if quote.author&.avatar&.attached? %>
            <div class="author-avatar mt-2">
              <%= image_tag quote.author.avatar,
                  width: 80,
                  class: "img-thumbnail",
                  style: "object-fit: cover; aspect-ratio: 1/1;" %>
            </div>
          <% end %>
        </cite>
      </footer>

    </blockquote>

    <cite class="animate-fade-up">
      <%= quote.date&.strftime("%B %d, %Y") || "Date not set" %>
      <% if quote.category.present? %>
        | <%= quote.category %>
      <% end %>
    </cite>

  </div>
</div>